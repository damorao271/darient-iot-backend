enum AlertKind {
  CO2
  OCCUPANCY_MAX
  OCCUPANCY_UNEXPECTED
}

model Alert {
  id         String     @id @default(cuid())
  spaceId    String
  space      Space      @relation(fields: [spaceId], references: [id])
  kind       AlertKind
  startedAt  DateTime
  resolvedAt DateTime?
  metaJson   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId, kind])
  @@index([spaceId, startedAt(sort: Desc)])
}
