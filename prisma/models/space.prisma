model Space {
  id           String   @id @default(cuid())
  placeId      String
  place        Place    @relation(fields: [placeId], references: [id])
  name         String
  reference    String?
  capacity     Int
  description  String?
  reservations Reservation[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
