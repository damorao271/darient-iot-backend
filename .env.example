# Server (PORT for backend's own compose, BACKEND_PORT for parent compose)
PORT=
BACKEND_PORT=
NODE_ENV=

# API Key for endpoint authentication (x-api-key or Authorization: Bearer <key>)
API_KEY=

# PostgreSQL (single source of truth - DATABASE_URL is derived from these)
DB_HOST=
DB_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# MQTT_BROKER_URL=
