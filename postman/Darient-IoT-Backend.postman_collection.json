{
  "info": {
    "_postman_id": "darient-iot-backend",
    "name": "Darient IoT Backend",
    "description": "Collection to test all endpoints of the Darient IoT Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "place_id",
      "value": ""
    },
    {
      "key": "space_id",
      "value": ""
    },
    {
      "key": "reservation_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "App",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Simple health check endpoint"
          }
        }
      ]
    },
    {
      "name": "Places",
      "item": [
        {
          "name": "Create Place",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.id) {",
                  "        pm.collectionVariables.set('place_id', json.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Main Office\",\n  \"latitude\": 40.4168,\n  \"longitude\": -3.7038\n}"
            },
            "url": {
              "raw": "{{base_url}}/places",
              "host": ["{{base_url}}"],
              "path": ["places"]
            },
            "description": "Create a new place. Required: name, latitude (-90 to 90), longitude (-180 to 180)"
          }
        },
        {
          "name": "Get All Places",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/places",
              "host": ["{{base_url}}"],
              "path": ["places"]
            },
            "description": "List all places"
          }
        },
        {
          "name": "Get Place by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/places/{{place_id}}",
              "host": ["{{base_url}}"],
              "path": ["places", "{{place_id}}"]
            },
            "description": "Get a single place by ID"
          }
        },
        {
          "name": "Update Place",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Office Name\",\n  \"latitude\": 40.4178,\n  \"longitude\": -3.7048\n}"
            },
            "url": {
              "raw": "{{base_url}}/places/{{place_id}}",
              "host": ["{{base_url}}"],
              "path": ["places", "{{place_id}}"]
            },
            "description": "Update a place. All fields are optional"
          }
        },
        {
          "name": "Delete Place",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{api_key}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/places/{{place_id}}",
              "host": ["{{base_url}}"],
              "path": ["places", "{{place_id}}"]
            },
            "description": "Delete a place"
          }
        }
      ]
    },
